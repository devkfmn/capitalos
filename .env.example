# Environment variables for local serverless API development (`vercel dev`).
#
# The Vite frontend (`npm run dev`) does NOT need any of these — its Firebase
# config is hardcoded in src/config/firebase.ts. These are only required by the
# functions in api/ (Hyperliquid + MEXC perpetuals, snapshots, market data),
# which is why exchange/perpetuals data only loads when the API layer runs.
#
# Easiest setup: link the project and pull real values automatically:
#   npx vercel login
#   npx vercel link          # link to the existing "capitalos" project
#   npm run env:pull         # writes the real values into .env.local
#   npm run dev:api          # runs `vercel dev` (frontend + api on one port)
#
# Or copy this file to .env.local and fill in the values manually.
# .env.local is git-ignored (see .gitignore: .env*.local).

# Firebase Admin service account JSON, as a single-line string.
# Used to verify the caller's Firebase ID token and read user settings
# server-side (api/perpetuals/hyperliquid.ts, api/perpetuals/mexc/*).
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"capitalos-a24f7","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@capitalos-a24f7.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}

# Shared secret guarding the daily cron endpoints. Not needed for perpetuals/
# exchange data; only required to manually hit api/snapshot/create or
# api/market/update-daily-prices.
# CRON_SECRET=

# CryptoCompare API key for crypto spot prices and USD→CHF rate.
# Server-only — used by api/market/crypto-prices and api/snapshot/create.
# Free tier: https://www.cryptocompare.com/cryptopian/api-keys
# CRYPTOCOMPARE_API_KEY=

# Optional: enables Firebase App Check (reCAPTCHA v3) in the frontend.
# Leave unset for local development.
# VITE_RECAPTCHA_V3_SITE_KEY=
