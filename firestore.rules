rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users can only access their own data
    match /users/{userId} {
      // Allow read/write if user owns this data
      allow read, write: if isOwner(userId);
      
      // Subcollections under user
      match /{collection}/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Shared market prices - any authenticated user can read.
    // All writes are server-only (Admin SDK bypasses these rules); clients
    // must never write shared market data, including coordination locks.
    match /marketDailyPrices/{dateKey} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin SDK can write

      match /symbols/{symbolKey} {
        allow read: if isAuthenticated();
        allow write: if false; // Only admin SDK can write
      }

      match /locks/{lockId} {
        allow read: if isAuthenticated();
        allow write: if false; // Only admin SDK can write
      }
    }

    // Shared symbols registry - read-only for clients; writes server-only.
    match /marketSymbolsRegistry/{symbolKey} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin SDK can write
    }
  }
}

